# Images
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.8.10
LLAMACPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server

# Ports
OPENWEBUI_PORT=3000
LLAMA_CHAT_PORT=8080
LLAMA_EMBED_PORT=8081

# Open WebUI basic
OPENWEBUI_AUTH=False
OPENWEBUI_ENABLE_PERSISTENT_CONFIG=False

# Open WebUI -> chat backend
OPENWEBUI_OPENAI_API_BASE_URL=http://llama-chat:8080/v1
OPENWEBUI_OPENAI_API_KEY=dummy

# Open WebUI -> RAG embeddings backend
OPENWEBUI_RAG_EMBEDDING_ENGINE=openai
OPENWEBUI_RAG_OPENAI_API_BASE_URL=http://llama-embed:8080/v1
OPENWEBUI_RAG_OPENAI_API_KEY=dummy
OPENWEBUI_RAG_EMBEDDING_MODEL=qwen3-embedding

# Chunking
OPENWEBUI_CHUNK_SIZE=800
OPENWEBUI_CHUNK_OVERLAP=100

# llama-chat
LLAMA_CHAT_MODEL=/models/qwen3-1.7b-instruct-q4_k_m.gguf
LLAMA_CHAT_CTX_SIZE=4096
LLAMA_CHAT_THREADS=4
LLAMA_CHAT_N_PARALLEL=1
LLAMA_CHAT_BATCH=512

# llama-embed
LLAMA_EMBED_MODEL=/models/qwen3-embedding-0.6b-q4_k_m.gguf
LLAMA_EMBED_CTX_SIZE=4096
LLAMA_EMBED_THREADS=4
LLAMA_EMBED_N_PARALLEL=1
LLAMA_EMBED_BATCH=512
